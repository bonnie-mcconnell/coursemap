# coursemap environment variables
# Copy this file to .env and fill in values before deploying.
# For local development, defaults (no .env needed) work fine.

# ── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# Comma-separated list of allowed CORS origins.
# Set to your domain in production.
# Example: ALLOWED_ORIGINS=https://coursemap.yourdomain.com
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Rate limiting ────────────────────────────────────────────────────────────
# Requests per minute for plan generation (the expensive endpoint)
PLAN_RATE_LIMIT=30
# Requests per minute for read-only endpoints (courses, majors)
READ_RATE_LIMIT=120

# ── Data paths ───────────────────────────────────────────────────────────────
# Override dataset location (defaults to datasets/ relative to project root)
# DATASETS_DIR=/data/coursemap/datasets

# ── Plan storage ─────────────────────────────────────────────────────────────
# SQLite DB path for saved plans. Defaults to plans.db in project root.
# PLAN_DB_PATH=/data/coursemap/plans.db

# Plan TTL in days (plans older than this are pruned on startup)
PLAN_TTL_DAYS=90

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FORMAT=json   # 'json' for production, 'text' for development
